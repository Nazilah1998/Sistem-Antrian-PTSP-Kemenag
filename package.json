{
  "name": "vite-project",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server:dev": "nodemon --watch server --ext ts,js --exec tsx server/index.ts",
    "dev:all": "concurrently -k -n \"FRONTEND,BACKEND\" -c \"cyan,green\" \"npm run dev\" \"npm run server:dev\"",
    "build": "prisma generate && vue-tsc -b && vite build",
    "start": "tsx server/index.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.1",
    "@prisma/client": "^5.14.0",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pinia": "^3.0.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.34",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.15",
    "prisma": "^5.14.0",
    "tailwindcss": "^4.3.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vue-tsc": "^3.2.8"
  }
}
